# ==============================================================================
#                 🏛️ KENBUN-AGENT DECOUPLED SWARM CONFIGURATION
# ==============================================================================
# Copy this file to '.env' and customize it for your local machine's environment.

# --- 1. CORE PATHS & STANDALONE DIRECTORIES ---
# Absolute path to your cloned kenbun-agent directory:
PROJECT_ROOT=/absolute/path/to/your/cloned/kenbun-agent
PROJECT_NAME=kenbun-agent

# --- 2. VECTOR DATABASE (LOCAL CHROMA STACK) ---
# Set to 'chromadb' inside docker-compose, or 'localhost' if running natively:
CHROMA_HOST=localhost
CHROMA_PORT=8000

# --- 3. HARDWARE-AGNOSTIC LLM GATEWAYS & PROVIDERS ---
# You can route to local Ollama, LM Studio, or cloud providers (OpenAI, Anthropic, Gemini).

# Option A: Local Ollama (Recommended Standalone Setup)
PRIMARY_LLM_URL=http://localhost:11434/v1
PRIMARY_LLM_MODEL=llama3.2:3b
OLLAMA_PULL_MODELS="llama3.2:3b deepseek-r1:8b"

# Option B: Local LM Studio (Alternative Local Rig)
# PRIMARY_LLM_URL=http://localhost:2065/v1
# PRIMARY_LLM_MODEL=qwen2.5-coder-14b-instruct

# Option C: Cloud Anthropic (High Reliability)
# PRIMARY_LLM_URL=https://api.anthropic.com/v1
# PRIMARY_LLM_MODEL=claude-3-5-sonnet-latest

# Option D: Cloud OpenAI
# PRIMARY_LLM_URL=https://api.openai.com/v1
# PRIMARY_LLM_MODEL=gpt-4o

# --- 4. FALLBACK GATEWAY ---
# Backup model URL and name when primary runs out of budget, is rate-limited, or goes offline.
FALLBACK_LLM_URL=https://api.openai.com/v1
FALLBACK_LLM_MODEL=gpt-4o-mini

# --- 5. API SECURITY KEYS (Fill in as needed) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# --- 6. GOVERNANCE & TELEMETRY BUDGETS ---
DAILY_BUDGET=50.00
TELEMETRY_ENABLED=true
NOTIFICATIONS_ENABLED=true
API_PORT=8001
MONITOR_PORT=8002
DASHBOARD_PORT=3000
