# PC Network Config
PC_IP_ADDRESS=127.0.0.1
LM_STUDIO_PORT=1234
LM_STUDIO_MODEL=local-model
CHROMA_PORT=8000

# Project Config
PROJECT_ROOT="./"
PROJECT_NAME=kenbun
OBSIDIAN_VAULT_PATH="./brain"

# External Projects
# Update these with absolute paths for local development
EXTERNAL_PORTFOLIO_PATH="/path/to/portfolio/route.ts"
EXTERNAL_TAQUERIA_PATH="/path/to/food/ElToroLoco"
GLOBAL_TEMPLATE_PATH="/path/to/templates"

# Cloud AI
GEMINI_API_KEY="your-api-key-here"
TWENTYONE_DEV_API_KEY="your-21st-dev-api-key-here"

# SIP Sentinel (3CX VoIP)
SIP_SERVER="192.168.1.100"
SIP_PORT=5060
SIP_USERNAME="105"
SIP_PASSWORD="enc:your_encrypted_password"
USER_PHONE_NUMBER="101"
LOCAL_IP="192.168.1.116"

# ── Local AI Stack (docker-compose.yml) ────────────────────────────
# Space-separated list of Ollama models to auto-pull on `make stack-up`.
#
# Lineup is sized for an RTX 5070 Ti (16 GB VRAM):
#   qwen2.5-coder:14b   ~9 GB  — primary code reviewer (Tier-1 Ensemble vote 1)
#   gemma2:9b           ~6 GB  — generalist reasoner    (Tier-1 vote 2)
#   phi3:14b            ~8 GB  — security/logic         (Tier-1 vote 3)
#   nomic-embed-text     ~0.3 GB — embeddings for ChromaDB / Hivemind
#
# Only one model is loaded into VRAM at a time (Ollama swaps); pulls store on disk.
# Drop down to :7b sizes if you want all 3 hot simultaneously.
OLLAMA_MODELS="qwen2.5-coder:14b gemma2:9b phi3:14b nomic-embed-text"
